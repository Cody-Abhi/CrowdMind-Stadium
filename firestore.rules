rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }
    
    function isEngineer() {
      return isSignedIn() && getUserData().role == 'engineer';
    }
    
    function isTechnician() {
      return isSignedIn() && getUserData().role == 'technician';
    }
    
    function isAuditor() {
      return isSignedIn() && getUserData().role == 'auditor';
    }
    
    function isStaff() {
      return isSignedIn() && (getUserData().role in ['admin', 'engineer', 'technician']);
    }

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    // Documents & OEM Manuals Ingestion Catalog
    match /documents/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isEngineer();
    }
    
    match /chunks/{chunkId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isEngineer();
    }

    // Equipment & Assets
    match /equipment/{eqId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isEngineer();
    }

    // Work Orders
    match /work_orders/{woId} {
      allow read: if isSignedIn();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    // Inspection Records
    match /inspection_records/{recordId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    // Standard Operating Procedures (SOPs)
    match /procedures/{procId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isEngineer();
    }

    // AI Query Logs (Audit trail)
    match /query_logs/{logId} {
      allow read: if isAdmin() || isEngineer() || isAuditor();
      allow create: if isSignedIn();
      allow update, delete: if false; // Immutable audit log
    }
    
    // Catch-all default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
